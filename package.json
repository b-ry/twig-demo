{
  "name": "twig-demo",
  "version": "1.0.0",
  "description": "Basic build tools for this twig demo",
  "devDependencies": {
    "sass": "^1.77.8"
  },
  "scripts": {
    "watch": "sass --watch --no-source-map --load-path=partials components/base/global.scss:css/global.css components/components/teaser/src:components/components/teaser components/elements/button/src:components/elements/button",
    "build": "sass --no-source-map --load-path=partials components/base/global.scss:css/global.css components/components/teaser/src:components/components/teaser components/elements/button/src:components/elements/button"
  }
}
